rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funzione helper per verificare se l'utente è loggato
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se l'utente autenticato è admin di uno specifico evento
    function isEventAdmin(eventId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/events/$(eventId))
        && get(/databases/$(database)/documents/events/$(eventId)).data.adminId == request.auth.uid;
    }

    // Regole per la collezione "users"
    match /users/{userId} {
      // Ognuno legge e scrive solo il proprio profilo
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Regole per la collezione "events"
    match /events/{eventId} {
      // Tutti gli utenti loggati possono leggere gli eventi (serve per la mappa e l'iscrizione)
      allow read: if isAuthenticated();
      // Solo gli utenti loggati possono creare eventi, e l'adminId deve coincidere col loro UID
      allow create: if isAuthenticated() && request.resource.data.adminId == request.auth.uid;
      // Solo il creatore (admin) dell'evento può modificarlo o eliminarlo
      allow update, delete: if isAuthenticated() && resource.data.adminId == request.auth.uid;
    }

    // Regole per la collezione "participants"
    match /participants/{participantId} {
      // Tutti gli utenti loggati possono leggere i partecipanti (serve per vedere i pin sulla mappa)
      allow read: if isAuthenticated();
      // Gli utenti possono creare, modificare o cancellare solo il PROPRIO documento di partecipazione
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // L'admin dell'evento può cancellare partecipazioni del proprio evento
      allow delete: if isEventAdmin(resource.data.eventId);
    }
  }
}
